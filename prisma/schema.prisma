
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @unique
  email String @unique
  username String @unique
  password String
  folders Folder[]
}

model Folder {
  id String @id @unique
  sharedFolders SharedFolder[]
  name String
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  files File[]
  folders Folder[] @relation("ParentChild")
  parentFolder Folder? @relation("ParentChild", fields: [parentFolderId], references: [id], onDelete: Cascade)
  parentFolderId String?
  createdAt DateTime @default(now())
}

model File {
  id String @id @unique
  name String 
  extension String
  fileUrl String @unique
  parentFolder Folder? @relation(fields: [parentFolderId], references: [id], onDelete: SetNull)
  parentFolderId String?
  size_bytes Int
  createdAt DateTime @default(now())
  mime_type String 
}

model Session {
  id String @id 
  sid       String   @unique
  data      String   
  expiresAt   DateTime
}

model SharedFolder {
  id String @id @unique
  sharedFolder Folder? @relation(fields: [sharedFolderId], references: [id], onDelete: Cascade)
  sharedFolderId String 
  expiresAt DateTime
  childShares SharedFolder[] @relation("ChildShare")
  parentShare SharedFolder? @relation("ChildShare", fields: [parentShareId], references: [id], onDelete: Cascade)
  parentShareId String? 
}
