
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  username String @unique
  password String
  folders Folder[]
}

model Folder {
  id Int @id @default(autoincrement())
  sharedFolders SharedFolder[]
  name String
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId Int
  files File[]
  folders Folder[] @relation("ParentChild")
  parentFolder Folder? @relation("ParentChild", fields: [parentFolderId], references: [id], onDelete: Cascade)
  parentFolderId Int?
  createdAt DateTime @default(now())
}

model File {
  id Int @id @default(autoincrement())
  name String 
  extension String
  fileUrl String @unique
  parentFolder Folder? @relation(fields: [parentFolderId], references: [id], onDelete: SetNull)
  parentFolderId Int?
  size_bytes Int
  createdAt DateTime @default(now())
  mime_type String 
}

model Session {
  id String @id 
  sid       String   @unique
  data      String   
  expiresAt   DateTime
}

model SharedFolder {
  id String @id
  sharedFolder Folder? @relation(fields: [sharedFolderId], references: [id], onDelete: Cascade)
  sharedFolderId Int 
  expiresAt DateTime
}
